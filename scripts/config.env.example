# deepfake-voice-inference launch configuration (template)
#
# Copy this file to scripts/config.env and edit the values for your machine:
#
#   cp scripts/config.env.example scripts/config.env
#
# scripts/config.env is gitignored so cluster addresses and signature secrets
# stay out of git. Anything you leave unset here falls back to the defaults
# below. For a one-off change without editing config.env, pass the flag
# straight through — it wins over the default, e.g.:
#
#   ./scripts/server.sh --video-camera-fps 20

# ---------------------------------------------------------------------------
# Cluster / SSH (used by tunnel.sh, and as documentation for server.sh)
# ---------------------------------------------------------------------------
SSH_KEY="/tmp/deepfake_voice_cluster_key"
SSH_PORT="22010"
SSH_USER="master"
SSH_HOST="62.183.4.208"
REMOTE_DIR="~/work/deepfake-test/voice-module/deepfake-voice-inference"

# ---------------------------------------------------------------------------
# Stream gateway host/port (server binds, client + tunnel connect)
# ---------------------------------------------------------------------------
STREAM_HOST="127.0.0.1"
STREAM_PORT="13000"

# ---------------------------------------------------------------------------
# Audio inference (RVC)
# ---------------------------------------------------------------------------
AUDIO_MODEL_PATH="assets/weights/voice_model.pth"
AUDIO_INDEX_PATH="assets/indices/voice_model.index"
AUDIO_INDEX_RATE="0.3"
AUDIO_SAMPLE_RATE="48000"
AUDIO_BLOCK_TIME="0.25"
AUDIO_F0METHOD="fcpe"

# ---------------------------------------------------------------------------
# Video inference (Deep-Live-Cam adapter)
# ---------------------------------------------------------------------------
VIDEO_DLC_ROOT="$HOME/workspace_w9line/deep_face/extracted/Deep-Live-Cam"
VIDEO_SOURCE_FACE="$VIDEO_DLC_ROOT/классный_чел_пнг.jpg"
VIDEO_PYTHON_PATH="$VIDEO_DLC_ROOT/.venv_dlc/bin/python"
VIDEO_CUDA_LIB_ROOT="$REPO_ROOT/.venv/lib/python3.10/site-packages"
VIDEO_EXECUTION_PROVIDER="cuda"
VIDEO_CAMERA_FPS="15.0"

# ---------------------------------------------------------------------------
# Client capture / preview
# ---------------------------------------------------------------------------
CLIENT_VIDEO_WIDTH="512"
CLIENT_VIDEO_HEIGHT="288"
CLIENT_VIDEO_FPS="15"
CLIENT_JPEG_QUALITY="65"

# ---------------------------------------------------------------------------
# C2PA-like stream signatures
#   SIGNATURE_POLICY: off | log | block   (server-side verification behavior)
#   SIGNATURE_KEY:    shared secret; when non-empty the client signs its streams
# ---------------------------------------------------------------------------
SIGNATURE_POLICY="off"
SIGNATURE_KEY=""
SIGNATURE_KEY_ID="deepfake-client-test"
# Server-side trusted key, "key_id=secret". Defaults to KEY_ID + KEY when set.
SIGNATURE_TRUSTED_KEY=""
